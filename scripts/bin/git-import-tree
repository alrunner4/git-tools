#!/usr/bin/bash
set -eu
if [ $# = 0 ]
then
	echo "$0: a tree argument is required" >&2
	exit 1
fi

git ls-tree -r "$@" | awk -F'\t' "$(cat <<AWK
{
	split(\$1, meta, " ")
	file = \$2
	stat = meta[1]
	oid = meta[3]
	stage = 0
	print stat " " oid " " stage "\t" file
}
AWK
)" | tee -a $(git rev-parse --git-dir)/index-info.todo
echo "$0: staged contents of tree $1 in index-info.todo (cf: git todo-update-index)" >&2
